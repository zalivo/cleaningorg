{
  "expo": {
    "name": "cleaning-org",
    "slug": "cleaning-org",
    "icon": "https://agent.expo.app/static/icon.png",
    "orientation": "default",
    "scheme": "acme",
    "userInterfaceStyle": "automatic",
    "web": {
      "output": "server"
    },
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "experiments": {
      "reactCompiler": true
    },
    "plugins": [
      "expo-font",
      "expo-image",
      "expo-router",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "18.5"
          },
          "android": {
            "minSdkVersion": 28,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "706ca359-624c-449d-a78c-0846921d2566"
      }
    },
    "owner": "cleaning-org",
    "ios": {
      "bundleIdentifier": "com.glenn032.cleaning-org"
    }
  }
}
